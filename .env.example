# VPS environment — copy to /home/ubuntu/research-desk/.env on the server
# The orchestrator and agent skills load this via dotenv / direct env vars.

# ─── Supabase (service role — server-side ONLY, never shipped to the browser) ───
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Ollama Cloud ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=https://api.ollama.ai
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_API_KEY=      # set if your Ollama Cloud account requires a key

# ─── OpenClaw ────────────────────────────────────────────────────────────────────
OPENCLAW_CLI_PATH=openclaw
OPENCLAW_WORKSPACES_ROOT=/home/ubuntu/.openclaw/workspaces

# ─── Orchestrator tuning ─────────────────────────────────────────────────────────
POLL_INTERVAL_MS=5000
LOCK_TIMEOUT_SECS=120
MAX_RETRIES=3
BACKOFF_BASE_MS=8000

# ─── Reviewer ────────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.70
