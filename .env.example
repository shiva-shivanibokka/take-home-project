# VPS environment — copy to ~/take-home-project/.env on the server.
# The orchestrator and all three agent skills load this via dotenv.

# ─── Supabase (service role — server-side ONLY, never shipped to the browser) ───
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── LLM provider (Groq free tier — Ollama-compatible API) ───────────────────────
# Groq free tier: 14,400 tokens/min, 500K/day. Get a key at console.groq.com.
OLLAMA_BASE_URL=https://api.groq.com/openai
OLLAMA_MODEL=llama-3.1-8b-instant   # default model (Collector + Reviewer)
WRITER_MODEL=llama-3.3-70b-versatile # Writer uses a larger model for brief quality
OLLAMA_API_KEY=gsk_...

# ─── OpenClaw workspaces ─────────────────────────────────────────────────────────
# Point directly at the repo's workspaces folder — no separate copy needed.
OPENCLAW_WORKSPACES_ROOT=/home/<your-username>/take-home-project/agents-openclaw/workspaces

# ─── Orchestrator tuning (defaults shown — no need to change for normal use) ─────
POLL_INTERVAL_MS=5000       # how often the poll loop ticks (ms)
LOCK_TIMEOUT_SECS=120       # stale lock expiry — matches Writer agent timeout
MAX_RETRIES=3               # per-stage retry limit before marking failed
BACKOFF_BASE_MS=8000        # base backoff; doubles each retry: 8s, 16s, 32s

# ─── Reviewer threshold ──────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.70   # below this → escalate to human
